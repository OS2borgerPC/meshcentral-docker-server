# ─── General ─────────────────────────────────────────────────────────────────
NODE_ENV=production
HOSTNAME=meshcentral.example.com

# ─── MeshCentral Configuration ───────────────────────────────────────────────
ALLOW_NEW_ACCOUNTS=false
ALLOW_PLUGINS=false
ALLOWED_ORIGIN=false
ARGS=
IFRAME=false
LOCAL_SESSION_RECORDING=true
MINIFY=true
REGEN_SESSIONKEY=false
WEBRTC=false

# Caddy handles TLS termination, so enable TLS offload and point the reverse
# proxy back at the public hostname on port 443.
TLS_OFFLOAD=true
REVERSE_PROXY=${HOSTNAME}
REVERSE_PROXY_TLS_PORT=443

# Internal ports (Caddy forwards to meshcentral:443 inside Docker)
PORT=443
REDIR_PORT=80

# Dynamic config rewrites config.json on every restart; set to false once you
# have a hand-crafted config.json you want to preserve.
DYNAMIC_CONFIG=false
CONFIG_FILE=/opt/meshcentral/meshcentral-data/config.json

# ─── Database ─────────────────────────────────────────────────────────────────
# Default: built-in NeDB (file-based, no extra config needed).
# Uncomment and fill in ONE of the sections below to use an external database.

# -- MongoDB --
USE_MONGODB=false
#MONGO_HOST=mongo
#MONGO_PORT=27017
#MONGO_USERNAME=meshcentral
#MONGO_PASS=changeme
#MONGO_URL=mongodb://meshcentral:changeme@mongo:27017/meshcentral

# -- PostgreSQL --
USE_POSTGRESQL=false
#PSQL_HOST=postgres
#PSQL_PORT=5432
#PSQL_USER=meshcentral
#PSQL_PASS=changeme
#PSQL_DATABASE=meshcentral

# -- MariaDB / MySQL --
USE_MARIADB=false
#MARIADB_HOST=mariadb
#MARIADB_PORT=3306
#MARIADB_USER=meshcentral
#MARIADB_PASS=changeme
#MARIADB_DATABASE=meshcentral
